          "target": "https://bookingwhale.co/search?q={search_term_string}",
          "query-input": "required name=search_term_string"
        },
        "inLanguage": "th-TH",
        "copyrightYear": "2025",
        "copyrightHolder": {
          "@type": "Organization",
          "name": "Booking Whale"
        }
      }
    </script>

    <title>{title}</title>
  </head>
  <body>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<style>
  html {
    font-family:
      "Helvetica Neue",
      Helvetica,
      "Noto Sans Thai",
      Arial,
      sans-serif;
  }

  body {
    margin: 0;
    padding: 0;
    line-height: 1.6;
    color: var(--text-primary);
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
    background: #ffffff;
  }

  h1 {
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: var(--text-primary);
  }

  h2 {
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--text-primary);
  }

  h3, h4, h5, h6 {
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text-primary);
  }

  p {
    font-weight: 400;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .text-balance {
    text-wrap: balance;
  }
</style>
