---
import { Image } from "astro:assets";
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";
import socialImg from "../assets/images/services/social.webp";
import schedulePlanImg from "../assets/images/services/schedule-plan.webp";
import cancelImg from "../assets/images/services/cancel.webp";
import loyaltyImg from "../assets/images/services/loyalty.webp";

interface Props {
  lang?: Lang;
}

const { lang = "th" } = Astro.props;

const serviceImages: Record<string, typeof socialImg> = {
  "/images/services/social.webp": socialImg,
  "/images/services/schedule-plan.webp": schedulePlanImg,
  "/images/services/cancel.webp": cancelImg,
  "/images/services/loyalty.webp": loyaltyImg,
};

const services = [
  {
    id: "booking",
    image: "/images/services/social.webp",
    alt: "Online booking system interface showing LINE OA integration with QR code and Rich Menu for instant customer booking",
    link: "#features",
    linkId: "bookingLink",
    bulletIds: ["bookingBullet1", "bookingBullet2", "bookingBullet3"],
  },
  {
    id: "schedule",
    image: "/images/services/schedule-plan.webp",
    alt: "Smart queue management dashboard showing automated scheduling system that prevents double bookings",
    link: "#features",
    linkId: "scheduleLink",
    bulletIds: ["scheduleBullet1", "scheduleBullet2", "scheduleBullet3"],
  },
  {
    id: "noshow",
    image: "/images/services/cancel.webp",
    alt: "LINE notification system showing appointment reminders and no-show prevention",
    link: "#features",
    linkId: "noshowLink",
    bulletIds: ["noshowBullet1", "noshowBullet2", "noshowBullet3"],
  },
  {
    id: "rebooking",
    image: "/images/services/loyalty.webp",
    alt: "Customer retention dashboard with automated rebooking messages and analytics",
    link: "#features",
    linkId: "rebookingLink",
    bulletIds: ["rebookingBullet1", "rebookingBullet2", "rebookingBullet3"],
  },
];
---

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "provider": {
      "@type": "Organization",
      "name": "Booking Whale",
      "url": "https://bookingwhale.co"
    },
    "serviceType": "Booking Management System",
    "description": "Complete LINE OA booking management platform for Thai businesses",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Booking Whale Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "LINE OA Online Booking",
            "description": "Easy booking through LINE Official Account and all online channels including QR codes and social media integration"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Smart Queue Management",
            "description": "Intelligent scheduling system that automatically manages queues and prevents double bookings"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "No-Show Reduction",
            "description": "LINE notification system with reminders and cancellation policies to reduce no-shows"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Customer Relationship Management",
            "description": "Automated rebooking messages and customer retention system through LINE messaging"
          }
        }
      ]
    },
    "areaServed": {
      "@type": "Country",
      "name": "Thailand"
    },
    "availableLanguage": ["Thai", "English"]
  }
</script>

<section
  id="services"
  class="section-padding bg-white"
  aria-labelledby="services-heading"
>
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
    <div data-animate="scroll-reveal">
      <div class="text-center mb-16">
        <h2
          id="services-heading"
          class="text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em]"
        >
          <span data-translate="ourServices">{t("ourServices", lang)}</span>
        </h2>
        <p
          data-translate="servicesDescription"
          class="text-xl text-gray-600 max-w-xl mx-auto mt-4 font-medium"
        >
          {t("servicesDescription", lang)}
        </p>
      </div>
    </div>

    <div
      data-animate="scroll-reveal"
      data-stagger-delay="0.12"
      class="grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-16 gap-y-10 lg:gap-y-12 max-w-5xl mx-auto"
    >
      {
        services.map((service) => (
          <div data-animate-child="fade-up" class="h-full">
            <div class="group">
              <div class="mb-4 overflow-hidden rounded-lg flex items-center justify-center">
                <Image
                  src={serviceImages[service.image]}
                  alt={service.alt}
                  width={385}
                  height={289}
                  class="max-h-[220px] w-auto object-contain transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <h3
                data-translate={`${service.id}Title`}
                class="text-xl font-bold text-gray-900 mb-3"
              >
                {t(`${service.id}Title`, lang)}
              </h3>
              <p
                data-translate={`${service.id}Desc`}
                class="text-base text-gray-600 leading-relaxed mb-4"
              >
                {t(`${service.id}Desc`, lang)}
              </p>

              <ul class="space-y-2 mb-5">
                {service.bulletIds.map((bulletId) => (
                  <li class="flex items-center gap-2 text-[13px] text-gray-600">
                    <svg
                      class="w-4 h-4 text-blue-600 flex-shrink-0"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    <span data-translate={bulletId}>{t(bulletId, lang)}</span>
                  </li>
                ))}
              </ul>

              <a
                href={service.link}
                data-translate={service.linkId}
                class="text-blue-600 hover:text-blue-700 font-semibold inline-flex items-center gap-1 transition-colors"
              >
                {t(service.linkId, lang)}
                <svg
                  class="w-4 h-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
