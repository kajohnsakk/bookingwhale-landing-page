---
import { getCollection } from 'astro:content';
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props { lang?: Lang; }
const { lang = "th" } = Astro.props;

const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

function getSlug(id: string) {
  return id.replace(/^(th|en)\//, '').replace(/\.md$/, '');
}
---

<section id="blog" class="section-padding bg-white" aria-labelledby="blog-heading">
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
    <div data-animate="scroll-reveal">
      <div class="text-center mb-16">
        <h2
          id="blog-heading"
          class="text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em]"
        >
          <span data-translate="blogTitle">{t("blogTitle", lang)}</span>
        </h2>
        <p data-translate="blogDescription" class="text-xl text-gray-600 max-w-xl mx-auto mt-4 font-medium">
          {t("blogDescription", lang)}
        </p>
      </div>
    </div>

    <div data-animate="scroll-reveal" data-stagger-delay="0.12" class="grid md:grid-cols-2 xl:grid-cols-3 gap-5 sm:p-6 lg:gap-8 mb-10 lg:mb-12">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString(lang === 'th' ? 'th-TH' : 'en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });

        return (
          <div data-animate-child="fade-up">
            <article class="group bg-white rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-sm transition-all duration-200 overflow-hidden h-full">
              <div class="p-5 sm:p-6 flex flex-col h-full">
                <div class="flex items-center gap-2 mb-3">
                  <span class="bg-blue-50 text-blue-600 text-[13px] font-semibold px-2.5 py-0.5 rounded-full">
                    {post.data.category}
                  </span>
                  <span class="text-[13px] text-gray-400">{formattedDate}</span>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-blue-600 transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-base text-gray-600 mb-4 leading-relaxed flex-1">
                  {post.data.description}
                </p>
                <a
                  href={`/blog/${getSlug(post.id)}`}
                  class="text-blue-600 hover:text-blue-700 text-[13px] font-medium flex items-center"
                  aria-label={`${lang === 'th' ? 'อ่านต่อ' : 'Read more'}: ${post.data.title}`}
                >
                  {lang === 'th' ? 'อ่านต่อ' : 'Read more'}
                  <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          </div>
        );
      })}
    </div>

    <div data-animate="fade-in" style="--delay: 0.15s">
      <div class="text-center mt-10 lg:mt-12">
        <a href="/blog" class="inline-flex items-center text-gray-600 hover:text-gray-900 font-medium py-3 px-6 rounded-lg border border-gray-200 hover:border-gray-300 transition-all duration-200">
          <span data-translate="viewAllBlogs">{t("viewAllBlogs", lang)}</span>
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
