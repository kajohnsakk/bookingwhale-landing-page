---
import { Image } from "astro:assets";
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";
import calendarIcon from "../assets/images/icons/calendar.webp";
import checkIcon from "../assets/images/icons/check.webp";
import customersIcon from "../assets/images/icons/customers.webp";
import notificationIcon from "../assets/images/icons/notification.webp";

interface Props { lang?: Lang; }
const { lang = "th" } = Astro.props;

const notifications = [
  {
    icon: calendarIcon,
    titleKey: "heroNotif1Title",
    subtitleKey: "heroNotif1Subtitle",
    position: "top-left",
  },
  {
    icon: checkIcon,
    titleKey: "heroNotif2Title",
    subtitleKey: "heroNotif2Subtitle",
    position: "bottom-right",
  },
  {
    icon: customersIcon,
    titleKey: "heroNotif3Title",
    subtitleKey: "heroNotif3Subtitle",
    position: "top-right",
  },
  {
    icon: notificationIcon,
    titleKey: "heroNotif4Title",
    subtitleKey: "heroNotif4Subtitle",
    position: "bottom-left",
  },
];

const positionClasses: Record<string, string> = {
  "top-left": "-top-2 -left-2 sm:-top-4 sm:-left-6 md:-left-4 lg:-left-8",
  "top-right": "top-8 -right-1 sm:top-6 sm:-right-4 md:-right-2 lg:-right-6",
  "bottom-right": "bottom-16 -right-1 sm:bottom-20 sm:-right-4 md:-right-2 lg:-right-8",
  "bottom-left": "bottom-4 -left-2 sm:bottom-8 sm:-left-4 md:-left-2 lg:-left-6",
};
---

{notifications.map((notif, i) => (
  <div
    class={`hero-notif absolute ${positionClasses[notif.position]} z-10 flex items-center gap-2 sm:gap-2.5 bg-white rounded-xl shadow-lg shadow-black/8 px-2.5 py-2 sm:px-3.5 sm:py-2.5 border border-gray-100 max-w-[180px] sm:max-w-[220px]`}
    data-notif-index={i}
  >
    <Image src={notif.icon} alt="" width={56} height={56} class="shrink-0 w-6 h-6 sm:w-7 sm:h-7" loading="lazy" />
    <div class="min-w-0">
      <p class="text-[10px] sm:text-xs font-semibold text-gray-900 truncate">
        {t(notif.titleKey as any, lang)}
      </p>
      <p class="text-[9px] sm:text-[10px] text-gray-500 truncate">
        {t(notif.subtitleKey as any, lang)}
      </p>
    </div>
  </div>
))}

<script>
  const notifs = document.querySelectorAll<HTMLElement>('.hero-notif');

  function showAll(delay: number) {
    notifs.forEach((el, i) => {
      setTimeout(() => {
        el.classList.remove('notif-exit');
        el.classList.add('notif-enter');
      }, delay + i * 900);
    });
  }

  function hideAll() {
    notifs.forEach((el, i) => {
      setTimeout(() => {
        el.classList.remove('notif-enter');
        el.classList.add('notif-exit');
      }, i * 300);
    });
  }

  showAll(1200);

  setInterval(() => {
    hideAll();
    setTimeout(() => showAll(400), notifs.length * 300 + 600);
  }, 10000);
</script>

<style>
  .hero-notif {
    opacity: 0;
    transform: scale(0.85) translateY(12px);
  }

  .hero-notif.notif-enter {
    animation: notifIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-notif.notif-exit {
    animation: notifOut 0.35s ease-in both;
  }

  @keyframes notifIn {
    from { opacity: 0; transform: scale(0.85) translateY(12px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }

  @keyframes notifOut {
    from { opacity: 1; transform: scale(1) translateY(0); }
    to { opacity: 0; transform: scale(0.95) translateY(-8px); }
  }
</style>
