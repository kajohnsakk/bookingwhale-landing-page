---
import Layout from "../layouts/Layout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import BookingModal from "./BookingModal.astro";
import { t, type Lang } from "../i18n/utils";

interface Props {
  bizId: string;
  lang?: Lang;
}

const { bizId, lang = "th" } = Astro.props;

const businessRegistry: Record<
  string,
  {
    slug: string;
    heroImage: string;
    icon: string;
    featureKeys: string[];
    painKeys: string[];
    painImages: string[];
    solKeys: string[];
    solImages: string[];
    statKeys: string[];
    bizTypeKeys: string[];
    bizTypeImages: string[];
  }
> = {
  bizFood: {
    slug: "food-beverage",
    heroImage: "/images/businesses/food-beverage.svg",
    icon: "M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z",
    featureKeys: ["bizFoodF1", "bizFoodF2", "bizFoodF3", "bizFoodF4"],
    painKeys: ["bizFoodPain1", "bizFoodPain2", "bizFoodPain3"],
    painImages: [
      "/images/businesses/detail/no-show.svg",
      "/images/businesses/detail/phone-chaos.svg",
      "/images/businesses/detail/walk-away.svg",
    ],
    solKeys: ["bizFoodSol1", "bizFoodSol2", "bizFoodSol3", "bizFoodSol4"],
    solImages: [
      "/images/businesses/detail/online-calendar.svg",
      "/images/businesses/detail/queue.svg",
      "/images/businesses/detail/coffee-shop.svg",
      "/images/businesses/detail/push-notifications.svg",
    ],
    statKeys: ["bizFoodStat1", "bizFoodStat2", "bizFoodStat3", "bizFoodStat4"],
    bizTypeKeys: ["bizFoodType1", "bizFoodType2", "bizFoodType3", "bizFoodType4", "bizFoodType5", "bizFoodType6"],
    bizTypeImages: [
      "/images/businesses/detail/restaurant-table.svg",
      "/images/businesses/detail/cafe-coffee.svg",
      "/images/businesses/detail/bar-night.svg",
      "/images/businesses/detail/bakery-order.svg",
      "/images/businesses/detail/food-truck-queue.svg",
      "/images/businesses/detail/catering-event.svg",
    ],
  },
  bizFitness: {
    slug: "fitness-sports",
    heroImage: "/images/businesses/fitness-sports.svg",
    icon: "M3 8.25V18a2.25 2.25 0 002.25 2.25h13.5A2.25 2.25 0 0021 18V8.25m-18 0V6a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 6v2.25m-18 0h18M5.25 6h.008v.008H5.25V6zM7.5 6h.008v.008H7.5V6zm2.25 0h.008v.008H9.75V6z",
    featureKeys: [
      "bizFitnessF1",
      "bizFitnessF2",
      "bizFitnessF3",
      "bizFitnessF4",
    ],
    painKeys: ["bizFitnessPain1", "bizFitnessPain2", "bizFitnessPain3"],
    painImages: [
      "/images/businesses/detail/class-full.svg",
      "/images/businesses/detail/trainer-chaos.svg",
      "/images/businesses/detail/ghost-member.svg",
    ],
    solKeys: [
      "bizFitnessSol1",
      "bizFitnessSol2",
      "bizFitnessSol3",
      "bizFitnessSol4",
    ],
    solImages: [
      "/images/businesses/detail/pilates.svg",
      "/images/businesses/detail/schedule.svg",
      "/images/businesses/detail/healthy-habit.svg",
      "/images/businesses/detail/reminders.svg",
    ],
    statKeys: ["bizFitnessStat1", "bizFitnessStat2", "bizFitnessStat3", "bizFitnessStat4"],
    bizTypeKeys: ["bizFitnessType1", "bizFitnessType2", "bizFitnessType3", "bizFitnessType4", "bizFitnessType5", "bizFitnessType6"],
    bizTypeImages: [
      "/images/businesses/detail/gym-fitness.svg",
      "/images/businesses/detail/yoga-studio.svg",
      "/images/businesses/detail/hyrox-race.svg",
      "/images/businesses/detail/functional-training.svg",
      "/images/businesses/detail/court-sports.svg",
      "/images/businesses/detail/dance-class.svg",
    ],
  },
};

const biz = businessRegistry[bizId];
const title = t(`${bizId}Title`, lang);
const contactPath = lang === "en" ? "/en/contact" : "/contact";
---

<Layout
  title={t(`${bizId}PageTitle`, lang)}
  description={t(`${bizId}PageDesc`, lang)}
  keywords={t(`${bizId}PageKeywords`, lang)}
  lang={lang}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Service",
        name: `Booking Whale - ${title}`,
        provider: {
          "@type": "Organization",
          name: "Booking Whale",
          url: "https://bookingwhale.co",
        },
        description: t(`${bizId}PageDesc`, lang),
        serviceType: "Booking Management System",
        areaServed: { "@type": "Country", name: "Thailand" },
      })}
    />
  </Fragment>

  <Header lang={lang} />

  <!-- Hero -->
  <section class="pt-36 pb-10 sm:pt-44 sm:pb-14 lg:pt-48 lg:pb-20 bg-gradient-to-b from-blue-50/60 to-white overflow-hidden">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16" data-animate="scroll-reveal">
        <div class="flex-1 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-blue-100 text-blue-600 text-sm font-bold mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={biz.icon} />
            </svg>
            {title}
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em] leading-[1.15] whitespace-pre-line">
            {t(`${bizId}HeroHeadline`, lang)}
          </h1>
          <p class="text-gray-500 mt-5 text-base sm:text-lg max-w-lg mx-auto lg:mx-0 leading-relaxed">
            {t(`${bizId}HeroSub`, lang)}
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
            <a href="#open-booking-modal" class="btn btn-primary btn-large">
              {t("bizDetailHeroCta", lang)}
            </a>
            <a href={contactPath} class="btn btn-secondary btn-large">
              {t("bizDetailCtaButton", lang)}
            </a>
          </div>
        </div>
        <div class="flex-shrink-0 w-[65%] sm:w-[50%] lg:w-[42%]">
          <img
            src={biz.heroImage}
            alt={title}
            class="w-full aspect-square object-contain drop-shadow-sm"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-16 sm:py-20 lg:py-24 bg-white">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="text-center mb-12 lg:mb-16" data-animate="scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-[2.5rem] font-black text-gray-900 tracking-[-0.03em]">
          {t("bizDetailPainTitle", lang)}
        </h2>
        <p class="text-gray-500 mt-3 text-base sm:text-lg max-w-md mx-auto">
          {t(`${bizId}PainSub`, lang)}
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 lg:gap-8" data-animate="scroll-reveal" data-stagger-delay="0.12">
        {biz.painKeys.map((key, i) => {
          return (
            <div class="rounded-2xl overflow-hidden border border-gray-200 bg-gray-50 h-full flex flex-col" data-animate-child="fade-up">
              <div class="flex items-center justify-center px-6 pt-6 pb-2 h-44">
                <img
                  src={biz.painImages[i]}
                  alt={t(`${key}Title`, lang)}
                  class="w-full max-w-40 h-auto"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="px-6 pb-6 pt-3 flex-1">
                <h3 class="text-lg font-bold text-gray-900 mb-2">
                  {t(`${key}Title`, lang)}
                </h3>
                <p class="text-gray-500 text-[15px] leading-relaxed">
                  {t(`${key}Desc`, lang)}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Solutions - Alternating Layout -->
  <section class="py-16 sm:py-20 lg:py-24 bg-gray-50 overflow-hidden">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="text-center mb-14 lg:mb-20" data-animate="scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-[2.5rem] font-black text-gray-900 tracking-[-0.03em]">
          {t("bizDetailSolutionTitle", lang)}
        </h2>
      </div>
      <div class="space-y-16 lg:space-y-24">
        {biz.solKeys.map((key, i) => {
          const isEven = i % 2 === 0;
          const textDir = isEven ? "left" : "right";
          const imgDir = isEven ? "right" : "left";
          return (
            <div class={`flex flex-col ${isEven ? "lg:flex-row" : "lg:flex-row-reverse"} items-center gap-10 lg:gap-16`}>
              <div data-animate={`slide-reveal-${textDir}`} class="flex-1">
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-blue-100 text-blue-600 text-xs font-bold uppercase tracking-wider mb-4">
                  {t(`${biz.featureKeys[i]}`, lang)}
                </span>
                <h3 class="text-xl sm:text-2xl lg:text-[1.75rem] font-black text-gray-900 mb-4">
                  {t(`${key}Title`, lang)}
                </h3>
                <p class="text-gray-600 leading-relaxed text-base sm:text-lg">
                  {t(`${key}Desc`, lang)}
                </p>
              </div>
              <div
                data-animate={`slide-reveal-${imgDir}`}
                style="--delay: 0.1s"
                class="flex-1 flex justify-center"
              >
                <div class="w-full max-w-[320px] sm:max-w-[380px]">
                  <img
                    src={biz.solImages[i]}
                    alt={t(`${key}Title`, lang)}
                    class="w-full h-auto"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Business Types -->
  <section class="py-16 sm:py-20 lg:py-24 bg-white">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="text-center mb-12 lg:mb-16" data-animate="scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-[2.5rem] font-black text-gray-900 tracking-[-0.03em]">
          {t(`${bizId}BizTypesTitle`, lang)}
        </h2>
        <p class="text-gray-500 mt-3 text-base sm:text-lg max-w-lg mx-auto">
          {t(`${bizId}BizTypesSub`, lang)}
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-5 lg:gap-6" data-animate="scroll-reveal" data-stagger-delay="0.08">
        {biz.bizTypeKeys.map((bt, i) => (
          <div class="rounded-2xl border border-gray-100 bg-gray-50/50 overflow-hidden group hover:border-blue-200 hover:shadow-md transition-all duration-300" data-animate-child="fade-up">
            <div class="flex items-center justify-center px-6 pt-6 pb-2 h-36 sm:h-40">
              <img
                src={biz.bizTypeImages[i]}
                alt={t(`${bt}Title`, lang)}
                class="w-full max-w-28 sm:max-w-32 h-auto group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="px-5 pb-5 pt-2 text-center">
              <div class="font-bold text-gray-900 text-[15px]">{t(`${bt}Title`, lang)}</div>
              <div class="text-gray-500 text-sm mt-1">{t(`${bt}Desc`, lang)}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12 sm:py-14 bg-gray-900">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 text-center" data-animate="scroll-reveal" data-stagger-delay="0.1">
        {biz.statKeys.map((stat) => (
          <div data-animate-child="fade-up">
            <div class="text-2xl sm:text-3xl lg:text-4xl font-black text-white tracking-tight">
              {t(`${stat}Value`, lang)}
            </div>
            <div class="text-gray-300 text-sm mt-1">
              {t(`${stat}Label`, lang)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 sm:py-20 lg:py-24 bg-gray-50">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
      <div class="text-center mb-12 lg:mb-16" data-animate="scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-[2.5rem] font-black text-gray-900 tracking-[-0.03em]">
          {t("bizDetailHowTitle", lang)}
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 lg:gap-12" data-animate="scroll-reveal" data-stagger-delay="0.15">
        {[1, 2, 3].map((step) => (
          <div class="text-center" data-animate-child="fade-up">
            <div class="w-12 h-12 rounded-full bg-blue-600 text-white text-lg font-black flex items-center justify-center mx-auto mb-5">
              {step}
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">
              {t(`bizDetailHowStep${step}Title`, lang)}
            </h3>
            <p class="text-gray-500 text-[15px] leading-relaxed max-w-xs mx-auto">
              {t(`bizDetailHowStep${step}Desc`, lang)}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 sm:py-28 lg:py-32 bg-blue-600 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-0 w-72 h-72 bg-white rounded-full -translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 right-0 w-96 h-96 bg-white rounded-full translate-x-1/3 translate-y-1/3"></div>
    </div>
    <div class="relative mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px] text-center" data-animate="scroll-reveal">
      <h2 class="text-2xl sm:text-3xl lg:text-[2.5rem] font-black text-white tracking-[-0.03em] leading-tight">
        {t("bizDetailCtaTitle", lang)}
      </h2>
      <p class="text-blue-100 mt-4 text-base sm:text-lg max-w-lg mx-auto leading-relaxed">
        {t("bizDetailCtaDesc", lang)}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#open-booking-modal"
          class="btn btn-large bg-white text-blue-600 hover:bg-blue-50 shadow-lg shadow-blue-700/20"
        >
          {t("bizDetailHeroCta", lang)}
        </a>
        <a
          href={contactPath}
          class="btn btn-large bg-white/15 text-white border border-white/30 hover:bg-white/25 backdrop-blur-sm"
        >
          {t("bizDetailCtaButton", lang)}
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-6 text-blue-200 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t("bizDetailTrust1", lang)}
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t("bizDetailTrust2", lang)}
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          {t("bizDetailTrust3", lang)}
        </div>
      </div>
    </div>
  </section>

  <Footer lang={lang} />
  <BookingModal lang={lang} />
</Layout>
