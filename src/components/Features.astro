---
import ScrollReveal from "./motion/ScrollReveal.tsx";
import SlideReveal from "./motion/SlideReveal.tsx";
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "th" } = Astro.props;

const features = [
  {
    eyebrow: "BOOKING",
    index: 1,
    image: "/features/online-booking.webp",
    alt: "Online booking system interface showing LINE OA integration with QR code and Rich Menu for instant customer booking",
  },
  {
    eyebrow: "SCHEDULING",
    index: 2,
    image: "/features/queue-scheduling.webp",
    alt: "Smart queue management dashboard showing automated scheduling system that prevents double bookings and manages appointments efficiently",
  },
  {
    eyebrow: "NOTIFICATIONS",
    index: 3,
    image: "/features/booking-reminders.webp",
    alt: "LINE notification system showing appointment reminders, no-show prevention, and automated rebooking messages for customer retention",
  },
  {
    eyebrow: "DATA",
    index: 4,
    image: "/features/booking-secure-data.webp",
    alt: "Comprehensive booking data management system with customer history, analytics dashboard, and digital signature verification feature",
  },
  {
    eyebrow: "ANALYTICS",
    index: 5,
    image: "/features/real-time-tracking.webp",
    alt: "Real-time business analytics dashboard showing booking statistics, revenue tracking, and business performance metrics for strategic planning",
  },
];
---

<section
  id="features"
  class="section-padding bg-white overflow-hidden"
  aria-labelledby="features-heading"
>
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
    <ScrollReveal client:visible>
      <div class="text-center mb-16">
        <h2
          id="features-heading"
          class="text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em]"
        >
          <span data-translate="whyChoose">{t("whyChoose", lang)}</span>
        </h2>
        <p
          data-translate="featuresDescription"
          class="text-xl text-gray-600 max-w-xl mx-auto mt-4 font-medium"
        >
          {t("featuresDescription", lang)}
        </p>
      </div>
    </ScrollReveal>

    <div class="space-y-12 lg:space-y-16">
      {
        features.map((feature) => {
          const isEven = feature.index % 2 !== 0;
          const textDir = isEven ? "left" : "right";
          const imgDir = isEven ? "right" : "left";
          return (
            <div
              class={`flex flex-col ${isEven ? "lg:flex-row" : "lg:flex-row-reverse"} items-center gap-8 sm:gap-10 lg:gap-14`}
            >
              <SlideReveal client:visible direction={textDir} className="flex-1">
                <span class="text-blue-600 text-[13px] font-semibold uppercase tracking-wide mb-3 block">
                  {feature.eyebrow}
                </span>
                <h3
                  data-translate={`feature${feature.index}Title`}
                  class="text-xl sm:text-2xl lg:text-[1.75rem] font-black text-gray-900 mb-4"
                >
                  {t(`feature${feature.index}Title`, lang)}
                </h3>
                <p
                  data-translate={`feature${feature.index}Desc`}
                  class="text-gray-600 leading-relaxed text-xl"
                >
                  {t(`feature${feature.index}Desc`, lang)}
                </p>
              </SlideReveal>

              <SlideReveal client:visible direction={imgDir} delay={0.1} className="flex-1 flex justify-center">
                <div class="w-full max-w-[340px] sm:max-w-[420px]">
                  <img
                    src={feature.image}
                    alt={feature.alt}
                    class="w-full h-auto rounded-xl"
                    loading="lazy"
                    decoding="async"
                    width="700"
                    height="525"
                  />
                </div>
              </SlideReveal>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
