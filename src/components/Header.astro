---
import { Image } from "astro:assets";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";
import logoImg from "../assets/images/logo.webp";

interface Props {
  lang?: Lang;
}
const { lang = "th" } = Astro.props;
---

<header
  data-header
  class="fixed top-0 left-0 right-0 bg-white/80 backdrop-blur-lg z-50"
>
  <nav class="mx-auto px-6 sm:px-10 lg:px-16 py-4 lg:py-5">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-8">
        <a href="/" class="flex items-center">
          <Image
            src={logoImg}
            alt="Booking Whale logo - LINE OA booking system for businesses in Thailand"
            width={80}
            height={80}
            class="w-8 h-8 sm:w-10 sm:h-10 rounded-lg"
            loading="eager"
            fetchpriority="high"
          />
        </a>
        <div class="hidden xl:flex items-center space-x-8">
          <a
            href="#services"
            data-translate="ourServices"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="เรียนรู้เหตุผลที่ต้องเลือก Booking Whale สำหรับธุรกิจของคุณ"
          >
            {t("ourServices", lang)}
          </a>
          <a
            href="#features"
            data-translate="whyChoose"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="ดูฟีเจอร์ครบครันของ Booking Whale ที่จะช่วยเพิ่มประสิทธิภาพธุรกิจ"
          >
            {t("whyChoose", lang)}
          </a>
          <div class="relative group">
            <button
              type="button"
              class="flex items-center gap-1 text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
              aria-haspopup="true"
              aria-expanded="false"
            >
              {t("businesses", lang)}
              <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200">
              <div class="bg-white rounded-xl shadow-lg border border-gray-100 py-2 min-w-[200px]">
                <a
                  href={lang === "en" ? "/en/businesses/food-beverage" : "/businesses/food-beverage"}
                  class="flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 transition-colors"
                >
                  <span class="text-sm font-medium text-gray-700">{t("bizFoodTitle", lang)}</span>
                </a>
                <a
                  href={lang === "en" ? "/en/businesses/fitness-sports" : "/businesses/fitness-sports"}
                  class="flex items-center gap-3 px-4 py-2.5 hover:bg-gray-50 transition-colors"
                >
                  <span class="text-sm font-medium text-gray-700">{t("bizFitnessTitle", lang)}</span>
                </a>
              </div>
            </div>
          </div>
          <a
            href="#integrations"
            data-translate="integrations"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="เชื่อมต่อทุกเครื่องมือที่ธุรกิจต้องการในที่เดียว"
          >
            {t("integrations", lang)}
          </a>
          <a
            href="#faq"
            data-translate="faq"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="คำตอบสำหรับคำถามที่พบบ่อยเกี่ยวกับ Booking Whale"
          >
            {t("faq", lang)}
          </a>
          <a
            href="/blog"
            data-translate="blog"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="อ่านบทความและเคล็ดลับการเพิ่มประสิทธิภาพธุรกิจ"
          >
            {t("blog", lang)}
          </a>
          <a
            href={lang === "en" ? "/en/contact" : "/contact"}
            data-translate="contact"
            class="text-gray-600 hover:text-gray-900 transition-colors duration-150 font-semibold text-[15px]"
            title="ติดต่อทีมงาน Booking Whale สำหรับความช่วยเหลือ"
          >
            {t("contact", lang)}
          </a>
        </div>
      </div>

      <div class="hidden xl:flex items-center space-x-4">
        <LanguageSwitcher />
        <a
          href={lang === "en" ? "/en/contact" : "/contact"}
          data-translate="startBookingNow"
          class="bg-blue-600 text-white text-sm px-6 py-1.5 rounded-full hover:bg-blue-700 transition-colors duration-150 font-bold"
        >
          {t("startBookingNow", lang)}
        </a>
      </div>

      <div class="xl:hidden flex items-center space-x-3">
        <LanguageSwitcher />
        <button
          id="mobileMenuToggle"
          class="p-2 text-gray-500 hover:text-gray-900 transition-colors w-8 h-8 flex flex-col justify-center items-center hover:bg-gray-50 rounded-lg"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <span
            class="hamburger-line block w-5 h-0.5 bg-current transition-all duration-300 ease-out"
          ></span>
          <span
            class="hamburger-line block w-5 h-0.5 bg-current transition-all duration-300 ease-out mt-1"
          ></span>
          <span
            class="hamburger-line block w-5 h-0.5 bg-current transition-all duration-300 ease-out mt-1"
          ></span>
        </button>
      </div>
    </div>

    <div
      id="mobileMenu"
      class="xl:hidden overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0"
    >
      <div class="pt-4 pb-6 border-t border-gray-100 mt-4">
        <div class="flex flex-col space-y-1">
          <a
            href="#services"
            data-translate="ourServices"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("ourServices", lang)}
          </a>
          <a
            href="#features"
            data-translate="whyChoose"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("whyChoose", lang)}
          </a>
          <div class="mobile-biz-dropdown">
            <button
              id="mobileBizToggle"
              type="button"
              class="flex items-center justify-between w-full text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
              onclick="toggleMobileBizDropdown()"
              aria-expanded="false"
              aria-controls="mobileBizSubmenu"
            >
              {t("businesses", lang)}
              <svg class="w-4 h-4 transition-transform duration-200 mobile-biz-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div id="mobileBizSubmenu" class="mobile-biz-submenu overflow-hidden max-h-0 transition-all duration-200">
              <a
                href={lang === "en" ? "/en/businesses/food-beverage" : "/businesses/food-beverage"}
                class="block text-gray-500 hover:text-gray-900 transition-colors font-medium py-2.5 pl-8 pr-4 rounded-lg hover:bg-gray-50 text-sm"
                onclick="closeMobileMenu()"
              >
                {t("bizFoodTitle", lang)}
              </a>
              <a
                href={lang === "en" ? "/en/businesses/fitness-sports" : "/businesses/fitness-sports"}
                class="block text-gray-500 hover:text-gray-900 transition-colors font-medium py-2.5 pl-8 pr-4 rounded-lg hover:bg-gray-50 text-sm"
                onclick="closeMobileMenu()"
              >
                {t("bizFitnessTitle", lang)}
              </a>
            </div>
          </div>
          <a
            href="#integrations"
            data-translate="integrations"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("integrations", lang)}
          </a>
          <a
            href="#faq"
            data-translate="faq"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("faq", lang)}
          </a>
          <a
            href="/blog"
            data-translate="blog"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("blog", lang)}
          </a>
          <a
            href={lang === "en" ? "/en/contact" : "/contact"}
            data-translate="contact"
            class="mobile-menu-link text-gray-600 hover:text-gray-900 transition-colors font-semibold py-3 px-4 rounded-lg hover:bg-gray-50"
            onclick="closeMobileMenu()"
          >
            {t("contact", lang)}
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  let lastY = 0;
  window.addEventListener(
    "scroll",
    () => {
      const current = window.scrollY;
      const header = document.querySelector("[data-header]") as HTMLElement;
      if (!header) return;
      if (current > 50) header.classList.add("header-scrolled");
      else header.classList.remove("header-scrolled");
      if (current > 200 && current > lastY)
        header.classList.add("header-hidden");
      else header.classList.remove("header-hidden");
      lastY = current;
    },
    { passive: true },
  );

  let isMobileMenuOpen = false;

  function toggleMobileMenu() {
    const mobileMenu = document.getElementById("mobileMenu");
    const mobileMenuToggle = document.getElementById("mobileMenuToggle");
    const hamburgerLines =
      mobileMenuToggle?.querySelectorAll<HTMLElement>(".hamburger-line");

    isMobileMenuOpen = !isMobileMenuOpen;
    mobileMenuToggle?.setAttribute("aria-expanded", String(isMobileMenuOpen));

    if (isMobileMenuOpen) {
      mobileMenu?.classList.remove("max-h-0", "opacity-0");
      mobileMenu?.classList.add("max-h-[600px]", "opacity-100");
      if (hamburgerLines) {
        hamburgerLines[0].style.transform = "rotate(45deg) translate(5px, 5px)";
        hamburgerLines[1].style.opacity = "0";
        hamburgerLines[2].style.transform =
          "rotate(-45deg) translate(7px, -6px)";
      }
    } else {
      mobileMenu?.classList.add("max-h-0", "opacity-0");
      mobileMenu?.classList.remove("max-h-[600px]", "opacity-100");
      if (hamburgerLines) {
        hamburgerLines[0].style.transform = "none";
        hamburgerLines[1].style.opacity = "1";
        hamburgerLines[2].style.transform = "none";
      }
    }
  }

  function closeMobileMenu() {
    if (isMobileMenuOpen) {
      toggleMobileMenu();
    }
  }

  document
    .getElementById("mobileMenuToggle")
    ?.addEventListener("click", toggleMobileMenu);

  document.addEventListener("click", (e) => {
    const header = document.querySelector("header");
    if (!header?.contains(e.target as Node) && isMobileMenuOpen) {
      closeMobileMenu();
    }
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 1280 && isMobileMenuOpen) {
      closeMobileMenu();
    }
  });

  function toggleMobileBizDropdown() {
    const submenu = document.getElementById("mobileBizSubmenu");
    const toggle = document.getElementById("mobileBizToggle");
    const chevron = toggle?.querySelector(".mobile-biz-chevron") as HTMLElement | undefined;
    if (!submenu || !toggle) return;
    const isOpen = !submenu.classList.contains("max-h-0");
    if (isOpen) {
      submenu.classList.add("max-h-0");
      submenu.classList.remove("max-h-40");
      chevron?.classList.remove("rotate-180");
      toggle.setAttribute("aria-expanded", "false");
    } else {
      submenu.classList.remove("max-h-0");
      submenu.classList.add("max-h-40");
      chevron?.classList.add("rotate-180");
      toggle.setAttribute("aria-expanded", "true");
    }
  }

  (window as any).toggleMobileMenu = toggleMobileMenu;
  (window as any).closeMobileMenu = closeMobileMenu;
  (window as any).toggleMobileBizDropdown = toggleMobileBizDropdown;
</script>

<style>
  .hamburger-line {
    transform-origin: center;
  }

  #mobileMenu {
    transition:
      max-height 0.3s ease-out,
      opacity 0.3s ease-out;
  }
</style>
