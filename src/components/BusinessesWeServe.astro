const learnMoreText = t("bizLearnMore", lang);
---

<section
  id="businesses"
  class="bg-white section-padding"
  aria-labelledby="businesses-heading"
>
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1100px]">
    <div data-animate="scroll-reveal">
      <div class="mb-12 lg:mb-16 text-center">
        <h2
          id="businesses-heading"
          class="text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em]"
        >
          <span data-translate="businessesTitle"
            >{t("businessesTitle", lang)}</span
          >
        </h2>
        <p
          data-translate="businessesDescription"
          class="text-lg text-gray-600 mt-3 font-medium max-w-lg mx-auto"
        >
          {t("businessesDescription", lang)}
        </p>
      </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-6 lg:gap-8 items-start">
      <div class="w-full lg:w-[50%] order-2 lg:order-1">
        <div
          class="biz-cards flex flex-row lg:flex-col gap-0 overflow-x-auto lg:overflow-x-visible snap-x snap-mandatory pb-2 lg:pb-0 -mx-6 px-6 sm:-mx-10 sm:px-10 md:-mx-14 md:px-14 lg:mx-0 lg:px-0"
          data-images={JSON.stringify(businesses.map((b) => b.image))}
          data-titles={JSON.stringify(
            businesses.map((b) => t(`${b.id}Title`, lang)),
          )}
          data-descs={JSON.stringify(
            businesses.map((b) => t(`${b.id}Desc`, lang)),
          )}
          data-features={JSON.stringify(businesses.map((b) => b.features))}
          data-slugs={JSON.stringify(businesses.map((b) => b.detailPage ? `${langPrefix}/businesses/${b.slug}` : ""))}
          data-learn-more={learnMoreText}
        >
          {
            businesses.map((biz, i) => (
              <button
                type="button"
                class:list={[
                  "biz-card group text-left px-4 py-4.5 rounded-lg transition-all duration-300 relative snap-center shrink-0 w-[75vw] sm:w-[50vw] lg:w-auto lg:shrink",
                  i === 0 && "bg-blue-50/50",
                ]}
              >
                <div class="flex items-center gap-3">
                  <svg
                    class:list={[
                      "w-5 h-5 shrink-0 transition-colors duration-300",
                      i === 0
                        ? "text-blue-600"
                        : "text-gray-400 group-hover:text-blue-600",
                    ]}
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d={biz.icon} />
                  </svg>
                  <h3
                    data-translate={`${biz.id}Title`}
                    class:list={[
                      "text-lg font-bold transition-colors duration-300",
                      i === 0
                        ? "text-blue-600"
                        : "text-gray-900 group-hover:text-blue-600",
                    ]}
                  >
                    {t(`${biz.id}Title`, lang)}
                  </h3>
                </div>
                <div
                  class:list={[
                    "biz-progress absolute bottom-0 left-0 h-[2px] w-full bg-blue-600 rounded-full origin-left",
                    i === 0 ? "block" : "hidden",
                  ]}
                  style="transform: scaleX(0);"
                />
              </button>
            ))
          }
        </div>
      </div>

      <div
        class="w-full lg:w-[50%] order-1 lg:order-2 flex flex-col justify-between"
      >
        <div class="flex-1 flex items-center justify-center">
          <img
            class="biz-image w-[60%] sm:w-[45%] lg:w-[75%] aspect-square object-contain transition-opacity duration-500"
            src={businesses[0].image}
            alt={t(`${businesses[0].id}Title`, lang)}
            loading="eager"
          />
        </div>
        <div class="bg-gray-50 rounded-xl p-4 lg:p-5 mt-6 w-full">
          <h3
            class="biz-caption-title text-lg lg:text-xl font-bold text-blue-600 text-center"
          >
            {t(`${businesses[0].id}Title`, lang)}
          </h3>
          <p class="biz-caption-desc text-sm text-gray-500 mt-1 text-center">
            {t(`${businesses[0].id}Desc`, lang)}
          </p>
          <div
            class="biz-caption-features grid grid-cols-2 gap-2 mt-4 max-w-sm mx-auto"
          >
            {
              businesses[0].features?.map((f: string) => (
                <div class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4 text-blue-600 shrink-0"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-sm text-gray-900">{f}</span>
                </div>
              ))
            }
          </div>
          <a
            href={businesses[0].detailPage ? `${langPrefix}/businesses/${businesses[0].slug}` : "#"}
            class="biz-caption-link inline-flex items-center gap-1 text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors mt-4 mx-auto"
            style={businesses[0].detailPage ? "" : "display:none"}
          >
            {learnMoreText}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const container = document.querySelector(".biz-cards");
    const cards = Array.from(document.querySelectorAll(".biz-card"));
    const image = document.querySelector(".biz-image") as HTMLImageElement;

    if (!container || !image || cards.length === 0) return;

    const images: string[] = JSON.parse(
      container.getAttribute("data-images") || "[]",
    );
    const titles: string[] = JSON.parse(
      container.getAttribute("data-titles") || "[]",
    );
    const descs: string[] = JSON.parse(
      container.getAttribute("data-descs") || "[]",
    );
    const features: string[][] = JSON.parse(
      container.getAttribute("data-features") || "[]",
    );
    const slugs: string[] = JSON.parse(
      container.getAttribute("data-slugs") || "[]",
    );
    const learnMoreLabel = container.getAttribute("data-learn-more") || "";
    const captionTitle = document.querySelector(".biz-caption-title");
    const captionDesc = document.querySelector(".biz-caption-desc");
    const captionFeatures = document.querySelector(".biz-caption-features");
    let activeIndex = 0;

    const DURATION = 5000;
    let autoTimer: ReturnType<typeof setTimeout> | null = null;
    let imageTimer: ReturnType<typeof setTimeout> | null = null;

    function startProgress() {
      const progress = cards[activeIndex]?.querySelector(
        ".biz-progress",
      ) as HTMLElement;
      if (!progress) return;
      progress.classList.remove("hidden");
      progress.style.transition = "none";
      progress.style.transform = "scaleX(0)";
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          progress.style.transition = `transform ${DURATION}ms linear`;
          progress.style.transform = "scaleX(1)";
        });
      });

      if (autoTimer) clearTimeout(autoTimer);
      autoTimer = setTimeout(() => {
        setActive((activeIndex + 1) % images.length);
      }, DURATION);
    }

    function escapeHtml(str: string) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    function setActive(index: number) {
      if (autoTimer) clearTimeout(autoTimer);
      if (imageTimer) clearTimeout(imageTimer);

      cards.forEach((card, i) => {
        const isActive = i === index;
        const title = card.querySelector("h3");
        const icon = card.querySelector("svg");
        const progress = card.querySelector(".biz-progress") as HTMLElement;

        card.classList.toggle("bg-blue-50/50", isActive);

        if (title) {
          title.classList.toggle("text-blue-600", isActive);
          title.classList.toggle("text-gray-900", !isActive);
          title.classList.toggle("group-hover:text-blue-600", !isActive);
        }
        if (icon) {
          icon.classList.toggle("text-blue-600", isActive);
          icon.classList.toggle("text-gray-400", !isActive);
          icon.classList.toggle("group-hover:text-blue-600", !isActive);
        }
        if (progress) {
          progress.classList.toggle("hidden", !isActive);
          progress.style.transition = "none";
          progress.style.transform = "scaleX(0)";
        }
      });

      activeIndex = index;

      if (window.innerWidth < 1024) {
        const scrollContainer = cards[0]?.parentElement as HTMLElement | null;
        const card = cards[index] as HTMLElement | undefined;
        if (scrollContainer && card) {
          const cardRect = card.getBoundingClientRect();
          const containerRect = scrollContainer.getBoundingClientRect();
          const scrollLeft =
            scrollContainer.scrollLeft +
            cardRect.left -
            containerRect.left -
            (scrollContainer.clientWidth - cardRect.width) / 2;
          scrollContainer.scrollTo({ left: scrollLeft, behavior: "smooth" });
        }
      }

      const targetIndex = index;
      image.style.opacity = "0";
      imageTimer = setTimeout(() => {
        if (activeIndex !== targetIndex) return;
        image.src = images[targetIndex];
        image.alt = titles[targetIndex];
        if (captionTitle) captionTitle.textContent = titles[targetIndex];
        if (captionDesc) captionDesc.textContent = descs[targetIndex];
        if (captionFeatures && features[targetIndex]) {
          captionFeatures.innerHTML = features[targetIndex]
            .map(
              (f) =>
                `<div class="flex items-center gap-2"><svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span class="text-sm text-gray-900">${escapeHtml(f)}</span></div>`,
            )
            .join("");
        }
        const linkEl = document.querySelector(".biz-caption-link");
        if (linkEl) {
          if (slugs[targetIndex]) {
            (linkEl as HTMLAnchorElement).href = slugs[targetIndex];
            (linkEl as HTMLElement).style.display = "";
          } else {
            (linkEl as HTMLElement).style.display = "none";
          }
        }
        image.style.opacity = "1";
      }, 300);

      startProgress();
    }

    cards.forEach((card, i) => {
      card.addEventListener("click", () => {
        if (i !== activeIndex) setActive(i);
      });
    });

    startProgress();
  })();
</script>

<style>
  .biz-cards {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .biz-cards::-webkit-scrollbar {
    display: none;
  }
</style>
