---
import ScrollReveal from "./motion/ScrollReveal.tsx";
import { StaggerContainer, StaggerItem } from "./motion/StaggerContainer.tsx";

const faqs = [
  {
    id: 'what-is',
    question: 'What is BookingWhale?',
    answer: 'BookingWhale is a next-generation booking platform designed to simplify service reservations for businesses and customers. We\'re currently in beta development.'
  },
  {
    id: 'when-launch',
    question: 'When will it be available?',
    answer: 'We\'re launching our beta version soon! Join our early access list to be among the first customers to try the platform and receive exclusive benefits from us.'
  },
  {
    id: 'cost',
    question: 'How much does it cost?',
    answer: 'BookingWhale will be free during our beta period. Early adopters will get special pricing when we launch our full platform.'
  },
  {
    id: 'features',
    question: 'What features will be included?',
    answer: 'Our platform will include automated booking, secure payments, business analytics, 24/7 support, and seamless integrations with existing tools.'
  },
  {
    id: 'support',
    question: 'Do you provide support?',
    answer: 'Yes! We provide 24/7 support via chat, email, and phone. Our dedicated team will help you get started and answer any questions.'
  },
  {
    id: 'security',
    question: 'Is my data secure?',
    answer: 'Absolutely. We use bank-level encryption and follow industry best practices to protect your data. Your information is safe with us.'
  }
];
---

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is BookingWhale?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BookingWhale is a next-generation booking platform designed to simplify service reservations for businesses and customers. We're currently in beta development."
      }
    },
    {
      "@type": "Question",
      "name": "When will it be available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We're launching our beta version soon! Join our early access list to be among the first customers to try the platform and receive exclusive benefits from us."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BookingWhale will be free during our beta period. Early adopters will get special pricing when we launch our full platform."
      }
    },
    {
      "@type": "Question",
      "name": "What features will be included?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our platform will include automated booking, secure payments, business analytics, 24/7 support, and seamless integrations with existing tools."
      }
    },
    {
      "@type": "Question",
      "name": "Do you provide support?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We provide 24/7 support via chat, email, and phone. Our dedicated team will help you get started and answer any questions."
      }
    },
    {
      "@type": "Question",
      "name": "Is my data secure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. We use bank-level encryption and follow industry best practices to protect your data. Your information is safe with us."
      }
    }
  ]
}
</script>

<section id="faq" class="section-padding bg-gray-50" aria-labelledby="faq-heading">
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
    <ScrollReveal client:visible>
      <div class="text-center mb-12">
        <h2
          id="faq-heading"
          class="text-[1.75rem] sm:text-[2.25rem] lg:text-[2.75rem] font-black text-gray-900 tracking-[-0.03em]"
        >
          <span data-translate="faqTitle">คำถามที่พบบ่อย</span>
        </h2>
        <p data-translate="faqDescription" class="text-xl text-gray-600 max-w-xl mx-auto mt-4 font-medium">
          มีคำถามเกี่ยวกับ BookingWhale? เราได้รวบรวมคำถามที่พบบ่อยไว้ที่นี่
        </p>
      </div>
    </ScrollReveal>

    <div class="max-w-4xl mx-auto">
      <StaggerContainer client:visible staggerDelay={0.06} className="flex flex-col gap-3">
        {faqs.map((faq, index) => (
          <StaggerItem variant="fade-up">
            <div class="bg-white rounded-lg border border-gray-200 hover:border-gray-300 transition-colors duration-200 overflow-hidden">
              <button
                class="faq-toggle w-full px-4 py-3 sm:px-5 sm:py-4 text-left flex items-center justify-between focus:outline-none"
                aria-expanded="false"
                aria-controls={`faq-${index}`}
                onclick={`toggleFAQ('faq-${index}')`}
              >
                <h3 data-translate={`${faq.id}Question`} class="text-lg font-semibold text-gray-900">
                  {faq.question}
                </h3>
                <svg
                  class="faq-icon w-5 h-5 text-gray-400 transform transition-transform duration-200 flex-shrink-0 ml-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div
                id={`faq-${index}`}
                class="faq-answer overflow-hidden"
                style="height: 0;"
              >
                <div class="px-4 pb-3 sm:px-5 sm:pb-4">
                  <p data-translate={`${faq.id}Answer`} class="text-base text-gray-600 leading-relaxed">
                    {faq.answer}
                  </p>
                </div>
              </div>
            </div>
          </StaggerItem>
        ))}
      </StaggerContainer>
    </div>
  </div>
</section>

<script>
  function toggleFAQ(faqId) {
    const faqAnswer = document.getElementById(faqId);
    const button = faqAnswer?.previousElementSibling as HTMLElement;
    const faqIcon = button?.querySelector('.faq-icon');
    const isOpen = faqAnswer?.dataset.open === 'true';

    document.querySelectorAll('.faq-answer[data-open="true"]').forEach((el) => {
      if (el.id === faqId) return;
      el.dataset.open = 'false';
      (el as HTMLElement).style.height = el.scrollHeight + 'px';
      el.previousElementSibling?.setAttribute('aria-expanded', 'false');
      requestAnimationFrame(() => {
        (el as HTMLElement).style.height = '0';
      });
      el.previousElementSibling?.querySelector('.faq-icon')?.classList.remove('rotate-180');
    });

    if (!isOpen) {
      faqAnswer.dataset.open = 'true';
      button?.setAttribute('aria-expanded', 'true');
      faqAnswer.style.height = faqAnswer.scrollHeight + 'px';
      faqIcon?.classList.add('rotate-180');
      faqAnswer.addEventListener('transitionend', () => {
        if (faqAnswer.dataset.open === 'true') {
          faqAnswer.style.height = 'auto';
        }
      }, { once: true });
    } else {
      faqAnswer.dataset.open = 'false';
      button?.setAttribute('aria-expanded', 'false');
      faqAnswer.style.height = faqAnswer.scrollHeight + 'px';
      requestAnimationFrame(() => {
        faqAnswer.style.height = '0';
      });
      faqIcon?.classList.remove('rotate-180');
    }
  }

  window.toggleFAQ = toggleFAQ;
</script>

<style>
  .faq-answer {
    transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-icon {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
