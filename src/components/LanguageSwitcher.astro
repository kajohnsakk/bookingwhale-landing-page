  var currentLang = 'th';
  var isEnglish = window.location.pathname.startsWith('/en');

  function initLanguage() {
    currentLang = isEnglish ? 'en' : 'th';
    localStorage.setItem('language', currentLang);
    updateToggle();
    updatePageContent();
  }

  function updateToggle() {
    document.querySelectorAll('.js-lang-slider').forEach(function(slider) {
      slider.style.transform = currentLang === 'en' ? 'translateX(100%)' : 'translateX(0)';
      slider.className = 'lang-toggle-slider js-lang-slider';
    });
    document.querySelectorAll('.js-lang-opt').forEach(function(opt) {
      var lang = opt.getAttribute('data-lang');
      if (lang === currentLang) {
        opt.classList.add('lang-active');
      } else {
        opt.classList.remove('lang-active');
      }
    });
  }

  function updatePageContent() {
    var t = translations[currentLang];
    document.querySelectorAll('[data-translate]').forEach(function(el) {
      var key = el.getAttribute('data-translate');
      if (key && t[key]) {
        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
          el.placeholder = t[key];
        } else if (key === 'heroDescription') {
          el.innerHTML = t.heroDescription + '<br><span class="text-base lg:text-lg text-gray-500">' + (t.heroTagline || '') + '</span>';
        } else {
          el.textContent = t[key];
        }
      }
    });
  }

  function animateSwitch(callback) {
    var toggles = document.querySelectorAll('.js-lang-toggle');
    var sliders = document.querySelectorAll('.js-lang-slider');
    toggles.forEach(function(t) { t.classList.add('lang-switching'); });
    sliders.forEach(function(s) { s.classList.add('lang-slider-squish'); });
    setTimeout(function() {
      callback();
      setTimeout(function() {
        sliders.forEach(function(s) { s.classList.remove('lang-slider-squish'); });
        toggles.forEach(function(t) { t.classList.remove('lang-switching'); });
      }, 150);
    }, 80);
  }

  function navigateToLang(targetLang) {
    var hash = window.location.hash || '';
    var targetPath;
    if (targetLang === 'en') {
      targetPath = '/en' + hash;
    } else {
      targetPath = '/' + hash;
    }
    window.location.href = targetPath;
  }

  function toggleLang() {
    animateSwitch(function() {
      var targetLang = currentLang === 'th' ? 'en' : 'th';
      currentLang = targetLang;
      localStorage.setItem('language', currentLang);
      updateToggle();
      updatePageContent();
      navigateToLang(targetLang);
    });
  }

  function switchLang(lang) {
    if (lang === currentLang) return;
    animateSwitch(function() {
      currentLang = lang;
      localStorage.setItem('language', currentLang);
      updateToggle();
      updatePageContent();
      navigateToLang(lang);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  function init() {
    initLanguage();

    document.querySelectorAll('.js-lang-toggle').forEach(function(toggle) {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        toggleLang();
      });
    });

  }

  window.switchLanguage = switchLang;
  window.toggleLanguageDropdown = toggleLang;
})();
</script>

<style>
  .lang-toggle-wrap {
    position: relative;
    z-index: 1000;
  }

  .lang-toggle {
    position: relative;
    display: flex;
    align-items: center;
    background: #f3f4f6;
    border-radius: 9999px;
    padding: 2px;
    cursor: pointer;
    border: 1px solid #e5e7eb;
    outline: none;
    min-height: 24px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
  }

  .lang-toggle:hover {
    border-color: #d1d5db;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.08);
  }

  .lang-toggle:active {
    transform: scale(0.96);
  }

  .lang-toggle.lang-switching {
    transform: scale(0.94);
  }

  .lang-toggle:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .lang-toggle-slider {
    position: absolute;
    top: 2px;
    left: 2px;
    width: calc(50% - 2px);
    height: calc(100% - 4px);
    background: white;
    border-radius: 9999px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }

  .lang-slider-squish {
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
                width 0.15s ease;
    width: calc(50% + 3px) !important;
  }

  .lang-toggle-option {
    position: relative;
    z-index: 1;
    padding: 0 8px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #9ca3af;
    pointer-events: none;
    transition: color 0.2s ease;
    line-height: 20px;
  }

  .lang-toggle-option.lang-active {
    color: #1f2937;
  }
</style>
