---
import ScrollReveal from "./motion/ScrollReveal.tsx";
import FadeIn from "./motion/FadeIn.tsx";
import ScaleReveal from "./motion/ScaleReveal.tsx";
---

<section class="bg-white pt-24 pb-20 lg:pt-32 lg:pb-32">
  <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px]">
    <div class="grid lg:grid-cols-2 gap-10 sm:gap-12 lg:gap-16 items-center">
      <div class="text-center lg:text-left">
        <FadeIn client:load>
          <p class="text-[13px] sm:text-sm font-bold uppercase tracking-[0.25em] text-gray-900 mb-6" data-translate="heroEyebrow">LINE OA BOOKING PLATFORM</p>
        </FadeIn>

        <ScrollReveal client:load delay={0.1}>
          <h1
            class="text-[2.25rem] sm:text-[2.75rem] lg:text-[3.25rem] font-black text-black tracking-[-0.03em] leading-[1.08]"
            itemProp="headline"
          >
            <span data-translate="heroTitle">ระบบจองผ่าน</span><span class="text-blue-600 whitespace-nowrap"> LINE OA</span>
          </h1>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.2}>
          <p
            data-translate="heroSubtitle"
            class="text-lg sm:text-xl lg:text-[22px] text-gray-700 mt-6 leading-relaxed max-w-lg mx-auto lg:mx-0 font-medium"
          >
            จองง่าย ขายไว เชื่อมต่อลูกค้าได้ทันที
          </p>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.25}>
          <p
            data-translate="heroDescription"
            class="text-base sm:text-lg lg:text-xl text-gray-600 mt-4 leading-relaxed max-w-lg mx-auto lg:mx-0 font-normal"
          >
            ระบบจองนัดหมาย จัดการคิว เก็บฐานข้อมูลลูกค้า สร้างระบบจองในแบบของคุณ เชื่อมต่อกับ LINE Official Account ใช้งานง่าย พร้อมเริ่มได้ทันที
          </p>
        </ScrollReveal>

        <ScrollReveal client:load delay={0.3}>
          <div class="flex flex-col sm:flex-row gap-4 items-center sm:justify-center lg:justify-start mt-10 max-w-sm mx-auto sm:max-w-none lg:mx-0">
            <button
              onclick="openBookingModal()"
              data-translate="startBookingNow"
              class="bg-blue-600 hover:bg-blue-700 text-white px-10 py-3.5 sm:px-12 sm:py-4 lg:px-14 lg:py-[18px] rounded-full font-bold text-base sm:text-lg transition-colors duration-200 w-full sm:w-auto min-w-[200px] sm:min-w-[220px]"
            >
              เริ่มใช้ฟรี
            </button>
            <a
              href="#features"
              data-translate="learnMore"
              class="text-blue-600 px-10 py-3.5 sm:px-12 sm:py-4 lg:px-14 lg:py-[18px] rounded-full font-bold text-base sm:text-lg border-2 border-blue-600 hover:bg-blue-50 transition-all duration-200 text-center w-full sm:w-auto min-w-[200px] sm:min-w-[220px]"
            >
              ดูฟีเจอร์ทั้งหมด
            </a>
          </div>
        </ScrollReveal>
      </div>

      <ScaleReveal client:load delay={0.15}>
        <div class="flex justify-center lg:justify-end">
          <img
            src="/features/online-booking.webp"
            alt="BookingWhale dashboard - LINE OA booking management system for Thai businesses"
            class="rounded-2xl w-full max-w-xl"
            width="700"
            height="525"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </div>
      </ScaleReveal>
    </div>
  </div>
</section>
