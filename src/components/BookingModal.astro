---
import { t } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

interface Props { lang?: Lang; }
const { lang = "th" } = Astro.props;

const businesses = [
  { key: "beauty", gif: "/images/icons/beauty.webp" },
  { key: "food", gif: "/images/icons/food.webp" },
  { key: "fitness", gif: "/images/icons/fitness.webp" },
  { key: "education", gif: "/images/icons/education.webp" },
  { key: "event", gif: "/images/icons/event.webp" },
  { key: "hospitality", gif: "/images/icons/hospitality.webp" },
  { key: "rental", gif: "/images/icons/rental.webp" },
  { key: "general", gif: "/images/icons/general.webp" },
  { key: "other", gif: "/images/icons/other.webp" },
];
---

<div id="bookingModal" class="fixed inset-0 bg-black/40 backdrop-blur-sm hidden z-50 items-center justify-center p-4">
  <div class="bg-white rounded-3xl max-w-md lg:max-w-2xl w-full max-h-[90vh] overflow-y-auto transform transition-all duration-300 scale-95 opacity-0 shadow-2xl" id="modalContent">

    <div class="px-7 pt-7 pb-3">
      <div class="flex items-center justify-between">
        <h2 id="modalTitle" data-translate="chooseService" class="text-lg font-bold text-gray-900">{t("chooseService", lang)}</h2>
        <button
          onclick="closeBookingModal()"
          class="w-7 h-7 flex items-center justify-center text-gray-300 hover:text-gray-500 rounded-full hover:bg-gray-50 transition-all duration-150"
          aria-label="Close modal"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <p id="modalDesc" data-translate="modalDescription" class="text-[13px] text-gray-400 mt-1">{t("modalDescription", lang)}</p>

      <div class="flex items-center justify-center gap-2 mt-4">
        <div id="dot1" class="w-6 h-1 rounded-full bg-blue-600 transition-all duration-300"></div>
        <div id="dot2" class="w-6 h-1 rounded-full bg-gray-200 transition-all duration-300"></div>
      </div>
    </div>

    <div id="wizardStep1" class="px-5 pb-5 pt-3 grid grid-cols-3 gap-2">
      {businesses.map((biz, i) => (
        <button
          onclick={`selectBusiness('${biz.key}')`}
          class="modal-biz-card group relative flex flex-col items-center text-center p-5 rounded-2xl border border-gray-100 hover:border-blue-600 active:border-blue-600 transition-all duration-150"
          style={`animation-delay: ${i * 40}ms`}
        >
          <div class="w-14 h-14 flex items-center justify-center mb-2">
            <img src={biz.gif} alt="" class="w-12 h-12 object-contain" loading="lazy" />
          </div>
          <span data-translate={`biz${biz.key.charAt(0).toUpperCase() + biz.key.slice(1)}Title`} class="text-[12px] font-medium text-gray-500 group-hover:text-gray-900 transition-colors duration-150 leading-tight">{t(`biz${biz.key.charAt(0).toUpperCase() + biz.key.slice(1)}Title` as any, lang)}</span>
        </button>
      ))}
    </div>

    <div id="wizardStep2" class="hidden px-5 pb-5 pt-3">
      <button onclick="goBackToStep1()" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-4 px-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        <span id="backLabel"></span>
      </button>
      <div id="subCategoryList" class="space-y-1.5 overflow-y-auto max-h-[50vh] px-1"></div>
    </div>

    <div class="px-7 pb-6 pt-2">
      <div class="h-px bg-gray-100 mb-4"></div>
      <div class="flex items-center justify-center gap-1.5 text-[12px] text-gray-400">
        <span data-translate="expertConsultantsAvailable">{t("expertConsultantsAvailable", lang)}</span>
        <a href="tel:+66805956458" class="text-blue-600 hover:text-blue-700 font-medium transition-colors" data-translate="callBooking">{t("callBooking", lang)}</a>
      </div>
    </div>
  </div>
</div>

<script>
  declare global {
    interface Window {
      openBookingModal: () => void;
      closeBookingModal: () => void;
      selectBusiness: (business: string) => void;
      goBackToStep1: () => void;
      selectSubCategory: (sub: string, e: Event) => void;
      submitOther: () => void;
    }
  }

  const subCategories: Record<string, { th: string[]; en: string[] } | null> = {
    food: {
      th: ['ร้านอาหาร', 'คาเฟ่', 'บาร์ & ผับ', 'เบเกอรี่'],
      en: ['Restaurant', 'Cafe', 'Bar & Pub', 'Bakery']
    },
    fitness: {
      th: ['ยิม & ฟิตเนส', 'สตูดิโอโยคะ', 'สนามกีฬา', 'เทรนเนอร์ส่วนตัว'],
      en: ['Gym & Fitness', 'Yoga Studio', 'Sports Court', 'Personal Trainer']
    },
    beauty: {
      th: ['ร้านทำผม', 'สปา & นวด', 'คลินิกความงาม', 'ร้านเล็บ'],
      en: ['Hair Salon', 'Spa & Massage', 'Beauty Clinic', 'Nail Salon']
    },
    event: {
      th: ['คอนเสิร์ต', 'เวิร์คช็อป', 'สัมมนา & อบรม', 'งานแสดง & นิทรรศการ'],
      en: ['Concert', 'Workshop', 'Seminar & Training', 'Exhibition & Show']
    },
    rental: {
      th: ['เช่ารถ', 'เช่าพื้นที่ & ห้องประชุม', 'เช่าอุปกรณ์', 'เช่าชุด & เครื่องแต่งกาย'],
      en: ['Car Rental', 'Space & Meeting Room', 'Equipment Rental', 'Costume & Apparel']
    },
    education: {
      th: ['ติวเตอร์', 'โรงเรียนสอนภาษา', 'คอร์สออนไลน์', 'ดนตรี & ศิลปะ'],
      en: ['Tutor', 'Language School', 'Online Course', 'Music & Art']
    },
    general: {
      th: ['ช่างซ่อม & บริการ', 'ทำความสะอาด', 'ช่างภาพ', 'ที่ปรึกษา'],
      en: ['Repair & Services', 'Cleaning', 'Photography', 'Consulting']
    },
    hospitality: {
      th: ['โรงแรม', 'รีสอร์ท', 'ทัวร์ & ทริป', 'แพ็คเกจท่องเที่ยว'],
      en: ['Hotel', 'Resort', 'Tour & Trip', 'Travel Package']
    },
    other: null
  };

  const bizTitles: Record<string, { th: string; en: string }> = {
    food: { th: 'ร้านอาหาร & เครื่องดื่ม', en: 'Food & Beverage' },
    fitness: { th: 'ฟิตเนส & กีฬา', en: 'Fitness & Sports' },
    beauty: { th: 'ความงาม & เวลเนส', en: 'Beauty & Wellness' },
    event: { th: 'อีเวนต์ & บัตรเข้างาน', en: 'Event & Ticket' },
    rental: { th: 'ธุรกิจให้เช่า', en: 'Rental Business' },
    education: { th: 'การศึกษา & การสอน', en: 'Education & Tutoring' },
    general: { th: 'บริการทั่วไป', en: 'General Services' },
    hospitality: { th: 'การท่องเที่ยว & ที่พัก', en: 'Hospitality & Travel' },
    other: { th: 'อื่นๆ', en: 'Others' }
  };

  function getLang() {
    const path = window.location.pathname;
    if (path.startsWith('/en')) return 'en';
    return 'th';
  }

  function openBookingModal() {
    const modal = document.getElementById('bookingModal');
    const content = document.getElementById('modalContent');
    const cards = document.querySelectorAll('.modal-biz-card');

    showStep(1);

    if (modal && content) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');

      cards.forEach(card => card.classList.remove('modal-biz-animate'));

      setTimeout(() => {
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
        cards.forEach(card => card.classList.add('modal-biz-animate'));
      }, 10);
    }
  }

  function closeBookingModal() {
    const modal = document.getElementById('bookingModal');
    const content = document.getElementById('modalContent');

    if (modal && content) {
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');

      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }, 250);
    }
  }

  function showStep(step: number) {
    const step1 = document.getElementById('wizardStep1');
    const step2 = document.getElementById('wizardStep2');
    const dot1 = document.getElementById('dot1');
    const dot2 = document.getElementById('dot2');

    if (step === 1) {
      step1?.classList.remove('hidden');
      step2?.classList.add('hidden');
      dot1?.classList.replace('bg-gray-200', 'bg-blue-600');
      dot2?.classList.replace('bg-blue-600', 'bg-gray-200');
    } else {
      step1?.classList.add('hidden');
      step2?.classList.remove('hidden');
      dot1?.classList.replace('bg-blue-600', 'bg-gray-200');
      dot2?.classList.replace('bg-gray-200', 'bg-blue-600');
    }
  }

  function selectBusiness(business: string) {
    const lang = getLang();
    const subs = subCategories[business];
    const backLabel = document.getElementById('backLabel');
    const subList = document.getElementById('subCategoryList');

    if (backLabel) backLabel.textContent = bizTitles[business]?.[lang] || business;

    if (!subs) {
      const placeholder = lang === 'th' ? 'ระบุประเภทธุรกิจของคุณ...' : 'Describe your business type...';
      const btnText = lang === 'th' ? 'ถัดไป' : 'Next';
      if (subList) {
        subList.innerHTML = '';
        const wrapper = document.createElement('div');
        wrapper.className = 'px-2 sub-card opacity-0';
        wrapper.style.animationDelay = '60ms';

        const input = document.createElement('input');
        input.id = 'otherInput';
        input.type = 'text';
        input.placeholder = placeholder;
        input.className = 'w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:border-blue-400 focus:ring-1 focus:ring-blue-400 transition-all';

        const submitBtn = document.createElement('button');
        submitBtn.className = 'w-full mt-3 py-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-xl transition-colors';
        submitBtn.textContent = btnText;
        submitBtn.addEventListener('click', () => submitOther());

        wrapper.appendChild(input);
        wrapper.appendChild(submitBtn);
        subList.appendChild(wrapper);
      }
      showStep(2);
      setTimeout(() => {
        document.querySelectorAll('.sub-card').forEach(c => c.classList.add('sub-animate'));
        document.getElementById('otherInput')?.focus();
      }, 50);
      return;
    }

    if (subList) {
      const items = subs[lang] || subs.th;
      subList.innerHTML = '';
      items.forEach((item: string, i: number) => {
        const btn = document.createElement('button');
        btn.className = 'sub-card w-full flex items-center justify-between px-4 py-3.5 rounded-xl text-left hover:bg-gray-50 transition-all duration-150 opacity-0';
        btn.style.animationDelay = `${i * 60}ms`;
        btn.addEventListener('click', (e) => selectSubCategory(item, e));

        const span = document.createElement('span');
        span.className = 'text-[13px] font-medium text-gray-700';
        span.textContent = item;

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'w-4 h-4 text-gray-300');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('stroke-width', '2');
        svg.setAttribute('viewBox', '0 0 24 24');
        svg.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>';

        btn.appendChild(span);
        btn.appendChild(svg);
        subList.appendChild(btn);
      });
    }

    showStep(2);
    setTimeout(() => {
      document.querySelectorAll('.sub-card').forEach(c => c.classList.add('sub-animate'));
    }, 50);
  }

  function goBackToStep1() {
    showStep(1);
  }

  function selectSubCategory(_sub: string, e: Event) {
    const btn = (e?.target as HTMLElement)?.closest('.sub-card');
    if (btn) {
      btn.classList.add('!bg-blue-50');
      const label = btn.querySelector('span');
      if (label) label.classList.add('!text-blue-600');
      const chevron = btn.querySelector('svg');
      if (chevron) {
        chevron.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>';
        chevron.classList.add('!text-blue-600');
      }
    }

    setTimeout(() => closeBookingModal(), 500);
  }

  function submitOther() {
    const input = document.getElementById('otherInput') as HTMLInputElement | null;
    if (input && input.value.trim()) {
      closeBookingModal();
    } else {
      input?.focus();
    }
  }

  document.addEventListener('click', (e: MouseEvent) => {
    const modal = document.getElementById('bookingModal');
    if (e.target === modal) closeBookingModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeBookingModal();
  });

  window.openBookingModal = openBookingModal;
  window.closeBookingModal = closeBookingModal;
  window.selectBusiness = selectBusiness;
  window.goBackToStep1 = goBackToStep1;
  window.selectSubCategory = selectSubCategory;
  window.submitOther = submitOther;
</script>

<style>
  @keyframes slideUp {
    from { transform: translateY(6px); opacity: 0.5; }
    to { transform: translateY(0); opacity: 1; }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .modal-biz-card.modal-biz-animate {
    animation: slideUp 0.2s ease-out both;
  }

  .sub-card.sub-animate {
    animation: fadeIn 0.25s ease-out forwards;
  }

</style>
