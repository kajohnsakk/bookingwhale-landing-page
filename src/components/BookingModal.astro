---
---

<div id="bookingModal" class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden z-50 items-center justify-center p-4">
  <div class="bg-white rounded-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto transform transition-all duration-300 scale-95 opacity-0 shadow-xl border border-gray-200" id="modalContent">
    <div class="p-8 border-b border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <h2 data-translate="chooseService" class="text-2xl font-semibold text-gray-900 mb-1">Select Your Solution</h2>
          <p data-translate="modalDescription" class="text-sm text-gray-500">Discover enterprise solutions tailored to your organizational needs</p>
        </div>
        <button
          onclick="closeBookingModal()"
          class="w-10 h-10 flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-50 rounded-lg transition-all duration-200"
          aria-label="Close modal"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="p-6 space-y-3">
      <button
        onclick="selectService('trainer')"
        class="w-full p-5 text-left border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-all duration-200 group flex items-center space-x-4"
      >
        <div class="w-12 h-12 bg-gray-100 text-gray-900 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm8 7h-2v7c0 1.1-.9 2-2 2h-1v-6c0-1.66-1.34-3-3-3s-3 1.34-3 3v6H8c-1.1 0-2-.9-2-2V9H4c-.55 0-1-.45-1-1s.45-1 1-1h16c.55 0 1 .45 1 1s-.45 1-1 1z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 data-translate="personalTrainingModal" class="text-base font-semibold text-gray-900 mb-0.5">Business Consulting</h3>
          <p data-translate="personalTrainingModalDesc" class="text-sm text-gray-500">Strategic guidance and expert consultation for business optimization</p>
        </div>
        <svg class="w-5 h-5 text-gray-300 group-hover:text-gray-500 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <button
        onclick="selectService('retail')"
        class="w-full p-5 text-left border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-all duration-200 group flex items-center space-x-4"
      >
        <div class="w-12 h-12 bg-gray-100 text-gray-900 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 data-translate="retailServicesModal" class="text-base font-semibold text-gray-900 mb-0.5">Resource Management</h3>
          <p data-translate="retailServicesModalDesc" class="text-sm text-gray-500">Comprehensive resource allocation and operational efficiency solutions</p>
        </div>
        <svg class="w-5 h-5 text-gray-300 group-hover:text-gray-500 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <button
        onclick="selectService('ticket')"
        class="w-full p-5 text-left border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-all duration-200 group flex items-center space-x-4"
      >
        <div class="w-12 h-12 bg-gray-100 text-gray-900 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M22 10v8c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2v-8c.83 0 1.5-.67 1.5-1.5S2.83 7 2 7V6c0-1.1.9-2 2-2h16c1.1 0 2 .9 2 2v1c-.83 0-1.5.67-1.5 1.5S21.17 10 22 10z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 data-translate="eventTicketsModal" class="text-base font-semibold text-gray-900 mb-0.5">Event Management</h3>
          <p data-translate="eventTicketsModalDesc" class="text-sm text-gray-500">Professional event planning and execution with enterprise-grade coordination</p>
        </div>
        <svg class="w-5 h-5 text-gray-300 group-hover:text-gray-500 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>

      <button
        onclick="selectService('other')"
        class="w-full p-5 text-left border border-gray-200 rounded-xl hover:border-gray-300 hover:bg-gray-50 transition-all duration-200 group flex items-center space-x-4"
      >
        <div class="w-12 h-12 bg-gray-100 text-gray-900 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <h3 data-translate="professionalServicesModal" class="text-base font-semibold text-gray-900 mb-0.5">Enterprise Solutions</h3>
          <p data-translate="professionalServicesModalDesc" class="text-sm text-gray-500">Custom enterprise solutions with scalable architecture and premium support</p>
        </div>
        <svg class="w-5 h-5 text-gray-300 group-hover:text-gray-500 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>

    <div class="p-6 border-t border-gray-100">
      <div class="text-center">
        <p data-translate="expertConsultantsAvailable" class="text-sm text-gray-500 mb-3">Our solution architects are available for enterprise consultation</p>
        <a
          href="tel:+1-800-BOOKING"
          class="inline-flex items-center space-x-2 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors duration-200 font-medium text-sm"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
          </svg>
          <span data-translate="callBooking">Call Enterprise Sales</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  function openBookingModal() {
    const modal = document.getElementById('bookingModal');
    const content = document.getElementById('modalContent');

    if (modal && content) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');

      setTimeout(() => {
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
      }, 10);
    }
  }

  function closeBookingModal() {
    const modal = document.getElementById('bookingModal');
    const content = document.getElementById('modalContent');

    if (modal && content) {
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');

      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }, 300);
    }
  }

  function selectService(service) {
    const serviceNames = {
      'trainer': 'Personal Training',
      'retail': 'Retail Services',
      'ticket': 'Event Tickets',
      'other': 'Professional Services'
    };

    alert(`You selected: ${serviceNames[service]}\n\nRedirecting you to the booking page...`);
    closeBookingModal();
  }

  document.addEventListener('click', (e) => {
    const modal = document.getElementById('bookingModal');
    if (e.target === modal) {
      closeBookingModal();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeBookingModal();
    }
  });

  window.openBookingModal = openBookingModal;
  window.closeBookingModal = closeBookingModal;
  window.selectService = selectService;
</script>
