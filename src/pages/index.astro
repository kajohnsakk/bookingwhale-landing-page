---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import BusinessesWeServe from '../components/BusinessesWeServe.astro';
import Features from '../components/Features.astro';
import Integrations from '../components/Integrations.astro';
import FAQ from '../components/FAQ.astro';
import Blog from '../components/Blog.astro';
import BookingModal from '../components/BookingModal.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Booking Whale - ระบบจองคิวผ่าน LINE OA | จัดการนัดหมาย ลด No-Show เพิ่มยอดจองซ้ำ"
  description="Booking Whale ระบบจองคิวออนไลน์ผ่าน LINE Official Account สำหรับธุรกิจไทย จัดคิวอัตโนมัติ แจ้งเตือนลด No-Show ชวนจองซ้ำอัตโนมัติ เชื่อมต่อทุกช่องทาง ใช้งานง่าย เพิ่มประสิทธิภาพธุรกิจของคุณ"
  keywords="ระบบจองคิว, LINE OA booking, จองคิวออนไลน์, นัดหมายออนไลน์, booking platform, ระบบจัดการนัดหมาย, ลด no-show, จองคิวผ่าน LINE, booking system Thailand, ระบบจองสำหรับธุรกิจ"
>
  <Header />

  <div class="sticky-section" data-sticky="1">
    <Hero />
  </div>
  <div class="sticky-section" data-sticky="2">
    <Services />
  </div>
  <div class="sticky-section" data-sticky="3">
    <BusinessesWeServe />
  </div>
  <div class="sticky-section" data-sticky="4">
    <Features />
  </div>
  <div class="sticky-section" data-sticky="5">
    <Integrations />
  </div>
  <div class="sticky-section" data-sticky="6">
    <FAQ />
  </div>
  <div class="relative z-20">
    <Blog />
    <Footer />
  </div>
  <BookingModal />

  <script>
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  </script>

  <script>
    const allSections = Array.from(
      document.querySelectorAll<HTMLElement>('.sticky-section')
    );

    function setStickyOffsets() {
      const vh = window.innerHeight;
      allSections.forEach((section) => {
        const h = section.offsetHeight;
        if (h > vh) {
          section.style.top = `${-(h - vh)}px`;
        } else {
          section.style.top = '0px';
        }
      });
    }

    function easeOutCubic(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    function updateSticky() {
      const vh = window.innerHeight;

      allSections.forEach((section, i) => {
        if (i === 0) return;
        const next = allSections[i + 1];
        if (!next) return;

        const nextTop = next.getBoundingClientRect().top;
        const raw = Math.max(0, Math.min(1, 1 - nextTop / vh));
        const p = easeOutCubic(raw);

        if (raw > 0) {
          const scale = 1 - p * 0.06;
          const radius = p * 28;
          const y = p * -20;
          const shadow = `0 ${4 + p * 16}px ${20 + p * 40}px rgba(0,0,0,${0.03 + p * 0.1})`;
          section.style.transform = `scale(${scale}) translateY(${y}px)`;
          section.style.borderRadius = `${radius}px`;
          section.style.filter = `brightness(${1 - p * 0.08})`;
          section.style.boxShadow = shadow;
        } else {
          section.style.transform = '';
          section.style.borderRadius = '';
          section.style.filter = '';
          section.style.boxShadow = '';
        }
      });
    }

    setStickyOffsets();
    updateSticky();

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateSticky();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    window.addEventListener('resize', () => {
      setStickyOffsets();
    });
  </script>

  <style>
    html {
      scroll-behavior: smooth;
    }

    [id] {
      scroll-margin-top: 80px;
    }

    ::-webkit-scrollbar {
      width: 8px;
    }

    ::-webkit-scrollbar-track {
      background: #f1f5f9;
    }

    ::-webkit-scrollbar-thumb {
      background: #cbd5e1;
      border-radius: 4px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: #94a3b8;
    }
  </style>

  <style is:global>
    .sticky-section {
      position: sticky;
      top: 0;
      transform-origin: center top;
      will-change: transform, filter;
      overflow: hidden;
    }

    .sticky-section[data-sticky="1"] { z-index: 11; }
    .sticky-section[data-sticky="2"] { z-index: 12; }
    .sticky-section[data-sticky="3"] { z-index: 13; }
    .sticky-section[data-sticky="4"] { z-index: 14; }
    .sticky-section[data-sticky="5"] { z-index: 15; }
    .sticky-section[data-sticky="6"] { z-index: 16; overflow: visible; }
  </style>
</Layout>
