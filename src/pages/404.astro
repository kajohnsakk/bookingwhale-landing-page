---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 - ไม่พบหน้านี้ | Booking Whale" description="ไม่พบหน้าที่คุณกำลังมองหา">
  <Header />

  <section class="pt-32 pb-24 min-h-[60vh] flex items-center">
    <div class="mx-auto px-6 sm:px-10 md:px-14 lg:px-24 max-w-[1400px] text-center">
      <p class="text-8xl font-black text-blue-600 mb-4">404</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">ไม่พบหน้าที่คุณกำลังมองหา</h1>
      <p class="text-lg text-gray-600 mb-8 max-w-md mx-auto">
        หน้านี้อาจถูกย้าย ลบ หรือ URL อาจพิมพ์ผิด
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white px-8 py-3 rounded-full font-bold text-sm transition-colors">
          กลับหน้าหลัก
        </a>
        <a href="/blog" class="inline-flex items-center justify-center bg-gray-100 hover:bg-gray-200 text-gray-700 px-8 py-3 rounded-full font-bold text-sm transition-colors">
          อ่านบทความ
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
